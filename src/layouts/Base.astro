---
import "../styles/global.css";
import "../styles/markdown.css"
const { frontmatter } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <div class="markdown">
      {frontmatter.title ? (
        <>
          
        <button
            class="cursor-pointer inline-flex items-center gap-2 px-3 group hover:bg-amber-200 transition-colors duration-200 rounded"
            onclick="this.querySelector('.arrow').classList.toggle('rotate-90'); this.nextElementSibling.classList.toggle('hidden')"
        >
            <img src="/arrow.svg" class="arrow transition-transform duration-200 w-4 h-4" alt="" />
            <p class="text-4xl font-bold">{frontmatter.title}</p>
        </button>





        <div class="hidden pl-9 pt-2 pb-6">
            <slot />
        </div>
        </>
      ) : (
        <div class="collapsible-markdown">
          <slot />
        </div>
      )}
    </div>
    <script is:inline>
      document.querySelectorAll('.collapsible-markdown').forEach((root) => {
        const headings = Array.from(root.children).filter((node) => node.tagName === 'H2');

        headings.forEach((heading, index) => {
          if (index === 0) {
            return;
          }

          const section = document.createElement('section');
          section.className = 'md-collapse-section';

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'md-collapse-toggle';
          button.setAttribute('aria-expanded', 'false');

          const arrow = document.createElement('img');
          arrow.src = '/arrow.svg';
          arrow.alt = '';
          arrow.className = 'md-collapse-arrow';

          const label = document.createElement('span');
          label.textContent = heading.textContent ?? '';

          button.append(arrow, label);

          const content = document.createElement('div');
          content.className = 'md-collapse-content hidden';

          section.append(button, content);
          heading.before(section);
          heading.remove();

          let current = section.nextSibling;
          while (current && !(current.nodeType === Node.ELEMENT_NODE && current.tagName === 'H2')) {
            const next = current.nextSibling;
            content.appendChild(current);
            current = next;
          }

          button.addEventListener('click', () => {
            const expanded = button.getAttribute('aria-expanded') === 'true';
            button.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            arrow.classList.toggle('rotate-90', !expanded);
            content.classList.toggle('hidden', expanded);
          });
        });
      });
    </script>
  </body>
</html>