---
import '../styles/global.css' 
import About from './about.md'
import Info from './tournament-info.md'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Waterloo IV 2026</title>
	</head>
	<body>

		
		<div class="w-full">
			<div class="flex flex-row flex-wrap justify-between items-center w-full">
				<img class="w-1/6 object-contain border-4 border-[#FEE685] rotate-[0.7deg]" src="/pic1.png" alt="pic1"/>
				<img class="w-1/6 object-contain border-4 border-[#FEE685] rotate-[-0.9deg]" src="/pic2.png" alt="pic2"/>
				<img class="w-1/6 object-contain border-4 border-[#FEE685] rotate-[0.3deg]" src="/pic3.png" alt="pic3"/>
				<img class="w-1/6 object-contain border-4 border-[#FEE685] rotate-[-0.5deg]" src="/pic4.png" alt="pic4"/>
				<img class="w-1/6 object-contain border-4 border-[#FEE685] rotate-[0.83deg]" src="/pic5.png" alt="pic5"/>
				<img class="w-1/6 object-contain border-4 border-[#FEE685] rotate-[-0.2deg]" src="/pic6.png" alt="pic6"/>
			</div>
		</div>
		

		<div class="pt-12">

		
			<div class="flex flex-col items-center">
				<div class="flex flex-col items-start mx-5">
					

					<div class=" bg-amber-200 p-2 px-4 rounded items-start">
						<p class="text-5xl font-bold text-[#3D2F2F]">Waterloo IV 2026 Tournament Package</p>
					</div>

					

					<div class="max-w-6xl mt-6">
						<About />
					</div>

					<div class="max-w-6xl mt-6">
						<Info />
					</div>

					<div class="max-w-6xl">
						<Info />
					</div>

					<div class="max-w-6xl">
						<Info />
					</div>

					<div class="max-w-6xl">
						<Info />
					</div>


				</div>

			</div>

		</div>




		<div class="flex flex-col items-center mt-24">
			<p>this is a footer</p>
		</div>


		







		
	</body>
</html>
