---
import '../styles/global.css';
import '../styles/markdown.css';
import { frontmatter as info } from './tournament-info.md';
import HeroSection from '../components/HeroSection.astro';
import TournamentIntro from '../components/TournamentIntro.astro';
import CollapsibleSection from '../components/CollapsibleSection.astro';
import SiteFooter from '../components/SiteFooter.astro';

const sections = info.sections;
const collapsibleSections = [
  sections.importantDates,
  sections.tournamentDetails,
  sections.fees,
  sections.chiefAdjudicators,
  sections.schedule,
  sections.logistics,
  sections.forms,
  sections.usefulLinks,
  sections.contacts,
  sections.socials,
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Waterloo IV 2026</title>
  </head>
  <body>
    <div class="pt-12">
      <div class="flex flex-col items-center">
        <div class="w-full">
          <HeroSection />

          <div class="max-w-6xl mt-6 w-full mx-auto px-5">
            <div class="markdown">
              <TournamentIntro pageTitle={info.pageTitle} intro={info.intro} callout={info.callout} />
              {collapsibleSections.map((section) => (
                <CollapsibleSection section={section} />
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <SiteFooter />
  </body>
</html>

<script is:inline>
  const registerToggle = document.querySelector('.register-toggle');
  const registerMenu = document.querySelector('.register-menu');
  const registerArrow = document.querySelector('.register-arrow');

  if (registerToggle && registerMenu && registerArrow) {
    const closeMenu = () => {
      registerMenu.classList.add('hidden');
      registerArrow.classList.remove('rotate-90');
      registerToggle.setAttribute('aria-expanded', 'false');
    };

    registerToggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const isHidden = registerMenu.classList.contains('hidden');
      if (isHidden) {
        registerMenu.classList.remove('hidden');
        registerArrow.classList.add('rotate-90');
        registerToggle.setAttribute('aria-expanded', 'true');
      } else {
        closeMenu();
      }
    });

    registerMenu.addEventListener('click', (event) => {
      event.stopPropagation();
    });

    document.addEventListener('click', closeMenu);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeMenu();
      }
    });
  }

  document.querySelectorAll('.md-collapse-toggle').forEach((toggle) => {
    const content = toggle.nextElementSibling;
    const arrow = toggle.querySelector('.md-collapse-arrow');
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      arrow?.classList.toggle('rotate-90', !expanded);
      content?.classList.toggle('hidden', expanded);
    });
  });
</script>
